# =============================================
# ALPACA TRADING ENGINE - VARIABLES DE ENTORNO
# =============================================
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a .env
# 2. Rellena con tus valores reales
# 3. NUNCA subas el archivo .env a GitHub

# --- Alpaca API ---
ALPACA_API_KEY=TU_API_KEY_AQUI
ALPACA_SECRET_KEY=TU_SECRET_KEY_AQUI
PAPER_TRADING=True

# --- Base de datos ---
DB_PATH=/app/data/trades.db

# --- Logs ---
LOG_PATH=/app/data/engine.log

# --- API Server del Dashboard ---
API_HOST=0.0.0.0
API_PORT=8000
